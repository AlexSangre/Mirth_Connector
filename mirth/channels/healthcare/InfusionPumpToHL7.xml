    <resourceIds class="linked-hash-map">
      <entry><string>Default Resource</string><string>[Default Resource]</string></entry>
    </resourceIds>
    <queueBufferSize>1000</queueBufferSize>
    <channelDependencies/>
  </properties>

</channel>
