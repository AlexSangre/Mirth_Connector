          <sequenceNumber>0</sequenceNumber>
          <enabled>true</enabled>
          <script><![CDATA[
var snapshot = JSON.parse(msg);
channelMap.put('ts', snapshot.timestamp || new Date().toISOString());

var vitals = snapshot.devices &&
             snapshot.devices.plc_signosvitales &&
             snapshot.devices.plc_signosvitales.readings
           ? snapshot.devices.plc_signosvitales.readings
           : {};

channelMap.put('vitals', vitals);
logger.info('Vitals snapshot parsed: ' + snapshot.timestamp);
          ]]></script>
        </com.mirth.connect.plugins.javascriptstep.JavaScriptStep>
