      <transformer version="4.4.0">
        <elements>
          <com.mirth.connect.plugins.javascriptstep.JavaScriptStep version="4.4.0">
            <name>Build HL7 ORU^R01 — Vital Signs Monitor</name>
            <sequenceNumber>0</sequenceNumber>
            <enabled>true</enabled>
            <script><![CDATA[
// -----------------------------------------------------------------------
// HL7 v2.5.1 ORU^R01 — healthcare-v2 PatientMonitor
// LOINC codes: 8867-4 HR | 8480-6 SysBP | 8462-4 DiasBP |
//              59408-5 SpO2 | 9279-1 RR | 8310-5 Temp
// -----------------------------------------------------------------------
var v   = channelMap.get('vitals') || {};
var ts  = channelMap.get('ts')     || new Date().toISOString();

var hl7ts = ts.replace(/[-:T]/g,'').substring(0,14);
var msgId = 'VITALS' + hl7ts;

function obx(seq, loincCode, loincName, value, unit, refRange) {
  return 'OBX|' + seq + '|NM|' + loincCode + '^' + loincName + '^LN||' +
    (value !== null && value !== undefined ? value : '') +
    '|' + unit + '|' + refRange + '||||F|||' + hl7ts;
}

var lines = [
  'MSH|^~\\&|VITALS_MONITOR|HOSPITAL_ICU|MIRTH_CONNECT|OPENEMR|' + hl7ts +
    '||ORU^R01^ORU_R01|' + msgId + '|P|2.5.1|||AL|AL|',
  'PID|1||PATIENT_001^^^HOSPITAL_ICU&HOSPITAL&L||Paciente^ICU||19800101|U|',
  'OBR|1|||85353-1^Vital signs panel^LN|||' + hl7ts + '|||||||||||||||F',
  obx(1, '8867-4',  'Heart rate',              v.signosvitales_frecuencia,   '/min',   '60-100'),
  obx(2, '8480-6',  'Systolic blood pressure',  v.signosvitales_presion_alta, 'mm[Hg]', '100-140'),
  obx(3, '8462-4',  'Diastolic blood pressure', v.signosvitales_presion_baja, 'mm[Hg]', '60-90'),
  obx(4, '59408-5', 'Oxygen saturation',        v.signosvitales_saturacion,   '%',      '95-100'),
  obx(5, '9279-1',  'Respiratory rate',         v.signosvitales_rate,         '/min',   '12-20'),
  obx(6, '8310-5',  'Body temperature',         v.signosvitales_temp,         'Cel',    '36.1-37.2'),
];

tmp = lines.join('\r');
            ]]></script>
          </com.mirth.connect.plugins.javascriptstep.JavaScriptStep>
        </elements>
