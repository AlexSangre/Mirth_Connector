      <transformer version="4.4.1">
        <elements>
          <com.mirth.connect.plugins.javascriptstep.JavaScriptStep version="4.4.1">
            <name>Build HL7 ORU^R01 — CPAP therapy parameters</name>
            <sequenceNumber>0</sequenceNumber>
            <enabled>true</enabled>
            <script><![CDATA[
// -----------------------------------------------------------------------
// HL7 v2.5.1 ORU^R01 — CPAP Simulator (healthcare-v2)
//
// OBX codes:
//   76222-9        Airway pressure goal [Ventilator]      cm[H2O]
//   CPAP-ACT-PRESS Actual airway pressure                 cm[H2O]  LOCAL
//   20112-0        Tidal volume Exhaled                   mL
//   3150-0         Inhaled O2 concentration               %
//   33438-3        Breath rate machine                    /min
//   CPAP-LEAK      Estimated mask leak                    %        LOCAL
// -----------------------------------------------------------------------
var c  = channelMap.get('cpap') || {};
var ts = channelMap.get('ts')   || new Date().toISOString();

var hl7ts = ts.replace(/[-:T]/g,'').substring(0,14);
var msgId = 'CPAP' + hl7ts;

function v(field) {
  var val = c[field];
  return (val !== null && val !== undefined) ? val : '';
}

function obx(seq, code, name, system, value, unit, refRange) {
  return 'OBX|' + seq + '|NM|' + code + '^' + name + '^' + system + '||' +
    value + '|' + unit + '|' + refRange + '||||F|||' + hl7ts;
}

var lines = [
  'MSH|^~\\&|CPAP_DEVICE|HOSPITAL_ICU|MIRTH_CONNECT|OPENEMR|' + hl7ts +
    '||ORU^R01^ORU_R01|' + msgId + '|P|2.5.1|||AL|AL|',
  'PID|1||PATIENT_001^^^HOSPITAL_ICU&HOSPITAL&L||Paciente^ICU||19800101|U|',
  // OBR: CPAP therapy panel — using local code; no standard LOINC panel for CPAP
  'OBR|1|||CPAP-PANEL^CPAP Therapy Parameters^LOCAL|||' + hl7ts + '|||||||||||||||F',
  // Therapy mode as a coded element (ST type)
  'OBX|1|ST|CPAP-MODE^Therapy mode^LOCAL||' + v('mode') + '||||||F|||' + hl7ts,
  // Therapy status
  'OBX|2|ST|CPAP-STATUS^Therapy status^LOCAL||' + v('therapy_status') + '||||||F|||' + hl7ts,
  // Clinical parameters
  obx(3, '76222-9',        'Airway pressure goal',     'LN',    v('pressure_set_cmh2o'),    'cm[H2O]', '4-20'),
  obx(4, 'CPAP-ACT-PRESS', 'Actual airway pressure',   'LOCAL', v('actual_pressure_cmh2o'), 'cm[H2O]', ''),
  obx(5, '20112-0',        'Tidal volume exhaled',      'LN',    v('measured_tidal_vol_ml'), 'mL',      '200-800'),
  obx(6, '3150-0',         'Inhaled O2 concentration',  'LN',    v('fio2_set_pct'),          '%',       '21-100'),
  obx(7, '33438-3',        'Breath rate machine',       'LN',    v('respiratory_rate_bpm'),  '/min',    '8-30'),
  obx(8, 'CPAP-LEAK',      'Estimated mask leak',       'LOCAL', v('leak_percentage'),       '%',       '0-24'),
];

tmp = lines.join('\r');
            ]]></script>
          </com.mirth.connect.plugins.javascriptstep.JavaScriptStep>
