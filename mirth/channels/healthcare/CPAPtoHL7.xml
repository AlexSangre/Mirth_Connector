        <com.mirth.connect.plugins.javascriptstep.JavaScriptStep version="4.4.1">
          <name>Parse CPAP snapshot</name>
          <sequenceNumber>0</sequenceNumber>
          <enabled>true</enabled>
          <script><![CDATA[
var snapshot = JSON.parse(msg);
channelMap.put('ts', snapshot.timestamp || new Date().toISOString());

var cpap = snapshot.devices &&
           snapshot.devices.cpap &&
           snapshot.devices.cpap.readings
         ? snapshot.devices.cpap.readings
         : {};

channelMap.put('cpap', cpap);
logger.info('CPAP snapshot parsed: ' + snapshot.timestamp +
            ' | status=' + (cpap.therapy_status || 'unknown'));
          ]]></script>
        </com.mirth.connect.plugins.javascriptstep.JavaScriptStep>
      </elements>
