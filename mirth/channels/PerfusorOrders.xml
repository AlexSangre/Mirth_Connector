        <com.mirth.connect.plugins.javascriptrule.JavaScriptRule version="4.4.0">
          <name>Parse ORM^O01 pharmacy order</name>
          <sequenceNumber>0</sequenceNumber>
          <enabled>true</enabled>
          <script><![CDATA[
// -----------------------------------------------------------------------
// Parse HL7 ORM^O01 message from OpenEMR
//
// Expected segments:
//   MSH — message header
//   PID — patient identifier (PID.3.1 = patient ID)
//   ORC — common order (ORC.1 = NW new / CA cancel)
//   RXO — pharmacy order (RXO.1.1 = drug name, RXO.2 = dose, RXO.4 = unit)
//   TQ1 — timing/quantity (TQ1.7 = rate in mL/h)
// -----------------------------------------------------------------------

// Medication → perfusor mapping (case-insensitive partial match)
var MEDICATION_MAP = [
  {keywords: ['morfin', 'morphin', 'fentanil', 'fentanyl'],  perfusor: 1},
  {keywords: ['noradrenal', 'norepinephrin', 'dopamin'],     perfusor: 2},
  {keywords: ['propofol', 'midazolam', 'ketamin'],           perfusor: 3},
];

function findPerfusor(drugName) {
  var name = (drugName || '').toLowerCase();
  for (var i = 0; i < MEDICATION_MAP.length; i++) {
    var entry = MEDICATION_MAP[i];
    for (var j = 0; j < entry.keywords.length; j++) {
      if (name.indexOf(entry.keywords[j]) >= 0) return entry.perfusor;
    }
  }
  return null;
}

// Parse HL7 — split into segments
var segments = {};
var lines = msg.split('\r');
for (var i = 0; i < lines.length; i++) {
  var seg = lines[i];
  if (seg.length < 3) continue;
  var name = seg.substring(0, 3);
  segments[name] = seg.split('|');
}

// Extract fields
var msh = segments['MSH'] || [];
var pid = segments['PID'] || [];
var orc = segments['ORC'] || [];
var rxo = segments['RXO'] || [];
var tq1 = segments['TQ1'] || [];

var orderAction  = orc[1]  || 'NW';                       // NW = new, CA = cancel
var orderId      = orc[2]  || ('ORD' + new Date().getTime());
var patientId    = (pid[3] || '').split('^')[0] || 'GIZMO_PATIENT_001';
var drugRaw      = (rxo[1] || '').split('^')[0];          // RXO.1.1 drug name
var dose         = parseFloat(rxo[2]) || 0;               // RXO.2 dose
var doseUnit     = rxo[4] || 'mg';                        // RXO.4 unit
var rateStr      = tq1[7] || '0';                         // TQ1.7 rate mL/h
var rate         = parseFloat(rateStr) || 0;

var perfusor = findPerfusor(drugRaw);

if (!perfusor) {
  logger.warn('PerfusorOrders: unknown medication "' + drugRaw + '" — cannot route');
  channelMap.put('skip', 'true');
  return;
}

logger.info('PerfusorOrders: ' + orderAction + ' ' + drugRaw +
  ' → perfusor ' + perfusor + ' rate=' + rate + ' mL/h');

channelMap.put('order_id',   orderId);
channelMap.put('action',     orderAction);
channelMap.put('perfusor',   perfusor);
channelMap.put('drug',       drugRaw);
channelMap.put('dose',       dose);
channelMap.put('dose_unit',  doseUnit);
channelMap.put('rate',       rate);
channelMap.put('patient_id', patientId);
channelMap.put('skip',       'false');
          ]]></script>
        </com.mirth.connect.plugins.javascriptrule.JavaScriptRule>
