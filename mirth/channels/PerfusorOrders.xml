            <script><![CDATA[
// Build the order JSON consumed by order_executor
// action: NW (new) → set flujo register; CA (cancel) → set flujo = 0
var action    = channelMap.get('action')    || 'NW';
var perfusor  = parseInt(channelMap.get('perfusor'), 10);
var rate      = parseFloat(channelMap.get('rate'))  || 0;
var dose      = parseFloat(channelMap.get('dose'))  || 0;

var order = {
  order_id:   channelMap.get('order_id'),
  patient_id: channelMap.get('patient_id'),
  action:     action,
  perfusor:   perfusor,
  drug:       channelMap.get('drug'),
  dose:       dose,
  dose_unit:  channelMap.get('dose_unit'),
  flujo:      action === 'CA' ? 0 : Math.min(Math.round(rate), 600),
  timestamp:  new Date().toISOString(),
};

tmp = JSON.stringify(order, null, 2);
            ]]></script>
